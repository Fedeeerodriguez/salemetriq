# ── IG PROSPECTOR — Backend (.env) ──────────────────────────────────────────
# Copiá a .env y completá. NO commitees el .env real.

# ── Supabase (base de datos) ─────────────────────────────────────────────────
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=
# service_role key — saltea RLS. La usa el backend para leer/escribir. NUNCA en el frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ── Apify — fuente de scraping (plan free, US$5 crédito/mes sin tarjeta) ──────
# No usa tu cuenta de IG → cero riesgo de ban. Sin token, el backend corre en
# MODO MOCK (perfiles de ejemplo) para poder probar todo el flujo sin gastar.
APIFY_TOKEN=
APIFY_ACTOR=apify/instagram-scraper
APIFY_MAX_RESULTS=200

# ── Anthropic (clasificador de nicho — Fase 4, opcional) ─────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Cifrado de credenciales de terceros en reposo ────────────────────────────
# Si queda vacía, se deriva de JWT_SECRET. Generá una con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
IGP_ENCRYPTION_KEY=

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# GENERÁ uno propio: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=cambiar-esto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# ── CORS — orígenes del frontend ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5182,http://localhost:5173
