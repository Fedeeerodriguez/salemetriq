# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=
# service_role key — saltea RLS. La usa el backend para ingesta de transcripts
# y para escribir los resultados del análisis IA. NUNCA exponer en el frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Analista IA — score de closers/setters) ───────────────────────
ANTHROPIC_API_KEY=
# claude-sonnet-5 (mejor análisis) | claude-haiku-4-5 (más barato)
ANTHROPIC_MODEL=claude-sonnet-5

# ── OpenAI (embeddings para búsqueda semántica de transcripts) ───────────────
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=cambiar-esto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# ── Ingesta externa (n8n / webhooks) ─────────────────────────────────────────
# Key compartida para que un proceso externo (n8n) suba transcripts/resúmenes
# vía POST /api/ingesta/* con header X-Ingest-Key. Si queda vacía, no se exige.
INGEST_INTERNAL_KEY=

# ── Conexiones (Fathom por usuario) ──────────────────────────────────────────
# URL pública del backend — Fathom la necesita para registrar el webhook.
PUBLIC_BACKEND_URL=https://tu-backend.easypanel.host
# Clave para cifrar credenciales de terceros (API key de Fathom). Generá una con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Si queda vacía, se deriva de JWT_SECRET (funciona, pero conviene una propia).
SMQ_ENCRYPTION_KEY=

# ── Telegram (setters mandan su resumen de setting al bot) ───────────────────
# Token del bot que te da @BotFather. Sin esto, la Fase A queda deshabilitada.
TELEGRAM_BOT_TOKEN=
# Secret arbitrario que se valida en el webhook (header X-Telegram-Bot-Api-Secret-Token).
# Poné cualquier string largo y usá el mismo al registrar el webhook.
TELEGRAM_WEBHOOK_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5180,http://localhost:5173
